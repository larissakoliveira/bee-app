VITE_CONTENTFUL_SPACE_ID=your_space_id
VITE_CONTENTFUL_ACCESS_TOKEN_DELIVERY_API=your_delivery_api_token_for_http_get
VITE_CONTENTFUL_ACCESS_TOKEN_MANAGEMENT=your_management_api_token_for_http_post_delete_patch_put

# Recommended for production: register “notify me” via your webhook (CMA token only on the server).
# Example: https://your-webhook.vercel.app/api/registerEmail  (or /register-email with vercel.json rewrite)
# VITE_EMAIL_REGISTER_API_URL=
# If the webhook sets EMAIL_REGISTER_SHARED_SECRET, set the same value here:
# VITE_EMAIL_REGISTER_SHARED_SECRET=

# Contentful environment id: master (production) or staging (see docs/VERCEL-STAGING-E-PRODUCAO.md)
# VITE_CONTENTFUL_ENVIRONMENT_ID=master

# Content model → Product content type → API identifier (GraphQL field becomes <id>Collection)
# VITE_CONTENTFUL_PRODUCT_CONTENT_TYPE_ID=product

# Required for “notify me”: same API identifier as webhook CONTENTFUL_EMAIL_REGISTRATION_CONTENT_TYPE_ID
VITE_CONTENTFUL_EMAIL_REGISTRATION_CONTENT_TYPE_ID=your_email_registration_content_type_id

# If CMA returns 422 unknown field, copy Field ID from Content model → each field (email / language / related product)
# VITE_CONTENTFUL_EMAIL_REGISTRATION_EMAIL_FIELD_ID=email
# VITE_CONTENTFUL_EMAIL_REGISTRATION_LANGUAGE_FIELD_ID=language
# VITE_CONTENTFUL_EMAIL_REGISTRATION_RELATED_PRODUCT_FIELD_ID=relatedProduct

# Optional: full URL of the first product image with Contentful image params (e.g. .../image.jpg?w=300&h=225&fit=fill&fm=avif&q=55)
# Copy from DevTools Network after one load. Injects <link rel="preload"> at build time for better Lighthouse LCP.
# VITE_LCP_IMAGE_PRELOAD_URL=
