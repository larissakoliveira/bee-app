VITE_CONTENTFUL_SPACE_ID=your_space_id
VITE_CONTENTFUL_ACCESS_TOKEN_DELIVERY_API=your_delivery_api_token_for_http_get
VITE_CONTENTFUL_ACCESS_TOKEN_MANAGEMENT=your_management_api_token_for_http_post_delete_patch_put

# Content model → Product content type → API identifier (GraphQL field becomes <id>Collection)
# VITE_CONTENTFUL_PRODUCT_CONTENT_TYPE_ID=product

# Must match Email registration content type API identifier — same value as webhook CONTENTFUL_EMAIL_REGISTRATION_CONTENT_TYPE_ID
# VITE_CONTENTFUL_EMAIL_REGISTRATION_CONTENT_TYPE_ID=eMailRegistration

# Optional: full URL of the first product image with Contentful image params (e.g. .../image.jpg?w=300&h=225&fit=fill&fm=avif&q=55)
# Copy from DevTools Network after one load. Injects <link rel="preload"> at build time for better Lighthouse LCP.
# VITE_LCP_IMAGE_PRELOAD_URL=
